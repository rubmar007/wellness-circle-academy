# Wellness Circle Academy — variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA committear el archivo .env (está en .gitignore).

# Entorno: local | production
APP_ENV=local

# Debug: true solo en local. En producción debe ser false.
APP_DEBUG=true

# URL base de la app (sin slash final).
APP_URL=http://localhost:8080

# Nombre visible de la marca.
APP_NAME="Wellness Circle Academy"

# Clave de aplicación. Genera 32 bytes aleatorios y pégalos en base64.
# Comando rápido en bash/WSL:   php -r "echo base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=

# Base de datos PostgreSQL (Neon).
# Formato esperado:
#   postgresql://USUARIO:PASSWORD@HOST/NOMBRE_DB?sslmode=require
# Importante: sslmode=require es obligatorio con Neon.
DATABASE_URL=

# Configuración de subida de imágenes (límites en bytes).
UPLOAD_MAX_BYTES=5242880
UPLOAD_ALLOWED_MIME="image/jpeg,image/png,image/webp"

# Mailgun (envío de emails — recuperación de contraseña).
# MAILGUN_REGION: 'us' (default) o 'eu'.
# MAILGUN_DOMAIN: dominio configurado en Mailgun (ej: mg.tudominio.com).
# MAIL_FROM_ADDRESS: debe pertenecer al dominio anterior o estar autorizado.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Wellness Circle Academy"
